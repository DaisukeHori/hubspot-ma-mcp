# ============================================
# HubSpot MA MCP Server - 環境変数設定
# ============================================

# ── 認証モード（必須）──
# "hubspot_token" : 各ユーザーが Bearer Token で自分の HubSpot トークンを渡す（デフォルト）
# "api_key"       : MCP_API_KEY でサーバーへのアクセスを制限 + 組織の HubSpot トークンを固定使用
AUTH_MODE=hubspot_token

# ── HubSpot アクセストークン ──
# AUTH_MODE=api_key の場合は必須（組織のトークンを固定設定）
# AUTH_MODE=hubspot_token の場合は不要（各ユーザーが Bearer で渡す）
# トークンは HubSpot > 設定 > 連携 > 非公開アプリ で作成
# HUBSPOT_ACCESS_TOKEN=pat-na1-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── MCP API キー ──
# AUTH_MODE=api_key の場合は必須
# 任意の文字列を設定し、MCPクライアントの Bearer Token としてこの値を指定
# MCP_API_KEY=your-secret-api-key-here
